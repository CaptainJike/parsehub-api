NODE_ENV=development
HOST=0.0.0.0
PORT=3000
API_PORT=3000

# Docker Compose uses these values to bootstrap PostgreSQL and Redis.
POSTGRES_DB=parsehub
POSTGRES_USER=parsehub
POSTGRES_PASSWORD=parsepwd
POSTGRES_PORT=5432
REDIS_PORT=6379

DATABASE_URL=postgresql://parsehub:parsepwd@localhost:5432/parsehub?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-at-least-32-characters
JWT_ISSUER=parsehub-api
JWT_AUDIENCE=parsehub-miniapp
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
ENABLE_MOCK_WECHAT=true

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PARSE_CACHE_TTL_SECONDS=900
PROVIDER_TIMEOUT_MS=25000
PARSE_TOTAL_TIMEOUT_MS=35000
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_TTL_SECONDS=180

DAILY_FREE_QUOTA=3
SIGNUP_BONUS_QUOTA=5
AD_REWARD_QUOTA=3
AD_REWARD_DAILY_LIMIT=10

WECHAT_PAY_MOCK=true
WECHAT_PAY_NOTIFY_SECRET=replace-in-production
